# Local frontend URL used by server-side API calls when API_BASE_URL is not set.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Browser + server mock API. Keep empty to use /api/mock in the browser and NEXT_PUBLIC_SITE_URL/api/mock on the server.
# NEXT_PUBLIC_API_BASE_URL=/api/mock

# Real Laravel API later. Example: https://api.example.com/api
# API_BASE_URL=http://localhost:3000/api/mock
