# Local frontend URL used by server-side API calls when API_BASE_URL is not set.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Website mock API mode:
# Keep API_BASE_URL and NEXT_PUBLIC_API_BASE_URL empty to use the built-in backend-like mock API at /api/mock.
# It supports SSR and client requests for home, catalogs, auth, checkout, library, and orders.
# NEXT_PUBLIC_API_BASE_URL=/api/mock

# Real Laravel API. Use the /api base because website feature code calls paths like /home and /courses.
API_BASE_URL=https://medical-courses.mustafafares.com/api
NEXT_PUBLIC_API_BASE_URL=https://medical-courses.mustafafares.com/api
